# ═══════════════════════════════════════════════════════════════
#  SunkenBot — متغيرات البيئة
#  انسخ هذا الملف إلى .env وأكمل القيم
#  على Render/Vercel/HF: أضف هذه المتغيرات في لوحة الإعدادات
# ═══════════════════════════════════════════════════════════════

# ─── Facebook Auth (أحد الخيارين يكفي) ──────────────────────
# الخيار ①: Email + Password (Fallback)
FB_EMAIL=your_facebook_email@example.com
FB_PASSWORD=your_facebook_password

# الخيار ②: 2FA Secret (إذا كان مفعّلاً على حسابك)
FB_2FA_SECRET=YOUR_2FA_BASE32_SECRET

# الخيار ③: AppState (الأفضل للإنتاج)
# ضع محتوى appstate.json كـ JSON string كامل
# APPSTATE=[ { "key": "...", "value": "...", "domain": "..." } ]

# ─── MongoDB (اختياري — يُمكّن حفظ الجلسات) ─────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/sunkenbot

# ─── AI APIs ─────────────────────────────────────────────────
# Cerebras (gpt / cerebras commands)
CEREBRAS_API_KEY=csk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Models (gptx command — GPT-4o)
GITHUB_MODELS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HuggingFace Space URL (groq / gemini / hf / img commands)
# مثال: https://YOUR-USERNAME-SPACE-NAME.hf.space
HF_SPACE_URL=https://your-space.hf.space

# ─── Render (تُضبط تلقائياً من Render Dashboard) ────────────
# PORT يُضبط تلقائياً — لا تغيّره
# PORT=10000

# هذا المتغير يُفعّل Keep-Alive (أضفه يدوياً من Dashboard → Environment)
RENDER_EXTERNAL_URL=https://your-bot-name.onrender.com
