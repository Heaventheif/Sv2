# ==============================
# SunkenBot — Mongoose Edition
# انسخ هذا الملف باسم .env وأضف قيمك
# على Render: أضفها في Environment Variables
# ==============================

# AppState (مطلوب — اختر أحد الخيارين)
# الخيار 1: ضع ملف appstate.json بجانب index.js
# الخيار 2: ضع المحتوى هنا
# APPSTATE=[{"key":"..."}]

# MongoDB (مطلوب للأوامر التي تحتاج DB)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/sunkenbot

# Gemini AI
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=

# Groq AI
GROQ_API_KEY=

# Pixabay
PIXABAY_API_KEY=

# FerDev API (لأمر sing)
FERDEV_API_KEY=
FERDEV_API_KEY2=
FERDEV_API_KEY3=

# GitHub Models
GITHUB_MODELS_TOKEN=

# Tumblr (لأمر random)
TUMBLR_API_KEY=

# Hugging Face (لأمر chess و hf و hfai)
HF_SCRAPER_URL=
HF_API_KEY=

# Keep-Alive port (افتراضي 3000)
PORT=3000

# رابط الخدمة على Render (لـ Keep-Alive)
# RENDER_EXTERNAL_URL=https://your-app.onrender.com

# Node memory limit
NODE_OPTIONS=--max-old-space-size=450
